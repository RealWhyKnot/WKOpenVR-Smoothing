# Auto detect text files and perform LF normalization
* text=auto

# Git hooks are bash scripts. CRLF line endings break them on Linux/macOS
# (`bash: \r: command not found`), so pin them to LF regardless of the
# checkout-time autocrlf setting.
.githooks/* text eol=lf

# YAML workflow files are parsed by GitHub Actions runners (Linux); pin LF.
.github/workflows/*.yml text eol=lf

# PowerShell tolerates either, but pinning CRLF avoids the autocrlf warning
# noise on checkout for Windows users.
*.ps1 text eol=crlf
